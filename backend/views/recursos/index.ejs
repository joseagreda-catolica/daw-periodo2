<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="bg-light">
  <%- include('../partials/header') %>

  <main class="container py-4">

    <!-- Alerts -->
    <% if (success && success.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0">Recursos Profesionales</h2>
      <% if (user) { %>
        <a href="/recursos/nuevo" class="btn btn-primary">
          + Compartir Recurso
        </a>
      <% } %>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <form action="/recursos" method="GET" class="row g-2 align-items-center">
          <div class="col-auto">
            <label class="col-form-label fw-semibold">Filtrar por tipo:</label>
          </div>
          <div class="col-md-4">
            <% let tipoFiltro = typeof tipo !== 'undefined' ? tipo : ''; %>

            <select name="tipo" class="form-select" onchange="this.form.submit()">
              <option value="">Todos los tipos</option>
              <option value="articulo" <%= tipoFiltro === 'articulo' ? 'selected' : '' %>>Artículos</option>
              <option value="video" <%= tipoFiltro === 'video' ? 'selected' : '' %>>Videos</option>
              <option value="curso" <%= tipoFiltro === 'curso' ? 'selected' : '' %>>Cursos</option>
              <option value="guia" <%= tipoFiltro === 'guia' ? 'selected' : '' %>>Guías</option>
              <option value="herramienta" <%= tipoFiltro === 'herramienta' ? 'selected' : '' %>>Herramientas</option>
            </select>
          </div>
        </form>
      </div>
    </div>

    <!-- Empty state -->
    <% if (recursos.length === 0) { %>
      <div class="text-center py-5">
        <h5 class="text-muted">No hay recursos disponibles</h5>
        <p class="text-secondary">Prueba seleccionando otro filtro.</p>
      </div>
    <% } else { %>

      <!-- Grid -->
      <div class="row g-4">
        <% recursos.forEach(r => { %>
          <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">

              <div class="card-body d-flex flex-column">

                <!-- Badge -->
                <span class="badge bg-primary mb-2 text-capitalize align-self-start">
                  <%= r.tipo %>
                </span>

                <!-- Title -->
                <h5 class="card-title">
                  <a href="<%= r.url_recurso %>" target="_blank" rel="noopener" class="text-decoration-none">
                    <%= r.titulo %>
                  </a>
                </h5>

                <!-- Description -->
                <% if (r.descripcion) { %>
                  <p class="card-text text-muted">
                    <%= r.descripcion.substring(0, 100) %><%= r.descripcion.length > 100 ? '...' : '' %>
                  </p>
                <% } %>

                <!-- Meta -->
                <p class="small text-secondary mt-auto">
                  Por <strong><%= r.nombre %> <%= r.apellido %></strong><br>
                  <%= new Date(r.fecha_publicacion).toLocaleDateString('es') %>
                </p>

                <!-- Button -->
                <a href="<%= r.url_recurso %>" target="_blank" rel="noopener"
                   class="btn btn-outline-primary btn-sm mt-2">
                  Ver recurso →
                </a>

              </div>

            </div>
          </div>
        <% }) %>
      </div>

    <% } %>

  </main>

  <%- include('../partials/footer') %>
</body>
</html>
