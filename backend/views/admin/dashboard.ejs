<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <%- include('../partials/header') %>

  <main class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0">Panel Administrativo</h2>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-6 col-md-3">
        <div class="card text-center shadow-sm border-0">
          <div class="card-body">
            <h3 class="fw-bold"><%= stats.totalUsuarios %></h3>
            <p class="text-muted mb-0">Usuarios</p>
          </div>
        </div>
      </div>

      <div class="col-6 col-md-3">
        <div class="card text-center shadow-sm border-0">
          <div class="card-body">
            <h3 class="fw-bold"><%= stats.totalEmpresas %></h3>
            <p class="text-muted mb-0">Empresas</p>
          </div>
        </div>
      </div>

      <div class="col-6 col-md-3">
        <div class="card text-center shadow-sm border-0">
          <div class="card-body">
            <h3 class="fw-bold"><%= stats.totalVacantes %></h3>
            <p class="text-muted mb-0">Vacantes</p>
          </div>
        </div>
      </div>

      <div class="col-6 col-md-3">
        <div class="card text-center shadow-sm border-0">
          <div class="card-body">
            <h3 class="fw-bold"><%= stats.totalPostulaciones %></h3>
            <p class="text-muted mb-0">Postulaciones</p>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-4">
        <a href="/admin/usuarios" class="text-decoration-none">
          <div class="card h-100 shadow-sm border-0 text-center">
            <div class="card-body d-flex flex-column justify-content-center">
              <h5 class="card-title">Gestión de Usuarios</h5>
            </div>
          </div>
        </a>
      </div>

      <div class="col-md-4">
        <a href="/admin/empresas" class="text-decoration-none">
          <div class="card h-100 shadow-sm border-0 text-center">
            <div class="card-body d-flex flex-column justify-content-center">
              <h5 class="card-title">Gestión de Empresas</h5>
            </div>
          </div>
        </a>
      </div>

      <div class="col-md-4">
        <a href="/admin/vacantes" class="text-decoration-none">
          <div class="card h-100 shadow-sm border-0 text-center">
            <div class="card-body d-flex flex-column justify-content-center">
              <h5 class="card-title">Gestión de Vacantes</h5>
            </div>
          </div>
        </a>
      </div>

      <div class="col-md-4">
        <a href="/admin/moderacion" class="text-decoration-none">
          <div class="card h-100 shadow-sm border-0 text-center">
            <div class="card-body d-flex flex-column justify-content-center">
              <h5 class="card-title">Moderación de Contenido</h5>
            </div>
          </div>
        </a>
      </div>

      <div class="col-md-4">
        <a href="/admin/recursos" class="text-decoration-none">
          <div class="card h-100 shadow-sm border-0 text-center">
            <div class="card-body d-flex flex-column justify-content-center">
              <h5 class="card-title">Gestión de Recursos</h5>
            </div>
          </div>
        </a>
      </div>
    </div>

  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>