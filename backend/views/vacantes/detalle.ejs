<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container mt-4">

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="card shadow-sm border-0">
      <div class="card-body">

        <!-- HEADER -->
        <div class="mb-4">
          <h1 class="fw-bold mb-1"><%= vacante.titulo %></h1>
          <p class="text-secondary fw-medium mb-2"><%= vacante.nombre_empresa %></p>

          <div class="d-flex flex-wrap gap-2 align-items-center">
            <span class="badge bg-primary-subtle text-primary">
              <%= vacante.tipo_contrato.replace('_', ' ') %>
            </span>

            <span class="badge bg-secondary-subtle text-secondary">
              <%= vacante.nivel_experiencia.replace('_', ' ') %>
            </span>

            <span class="text-muted small">
              <%= vacante.ubicacion || 'No especificada' %>
            </span>

            <% if (vacante.salario_min || vacante.salario_max) { %>
              <span class="fw-semibold text-success">
                $<%= vacante.salario_min || '?' %> - $<%= vacante.salario_max || '?' %>
              </span>
            <% } %>
          </div>
        </div>

        <hr>

        <!-- DESCRIPCIÓN -->
        <div class="mb-4">
          <h4 class="fw-semibold mb-3">Descripción del puesto</h4>
          <div class="text-muted">
            <%- vacante.descripcion.replace(/\n/g, '<br>') %>
          </div>
        </div>

        <!-- POSTULACIÓN -->
        <% if (user && user.rol === 'candidato') { %>
          <div class="mt-4">

            <% if (yaPostulado) { %>
              <div class="alert alert-success mb-0">
                Ya te has postulado a esta vacante.
              </div>
            <% } else { %>

              <h4 class="fw-semibold mb-3">Postularse</h4>

              <form action="/vacantes/<%= vacante.id_vacante %>/postular" method="POST">
                <div class="mb-3">
                  <label class="form-label">Carta de presentación (opcional)</label>
                  <textarea 
                    name="carta_presentacion" 
                    rows="5" 
                    class="form-control"
                    placeholder="Escribe por qué eres un buen candidato..."
                  ></textarea>
                </div>

                <button type="submit" class="btn btn-primary">
                  Enviar Postulación
                </button>
              </form>

            <% } %>

          </div>

        <% } else if (!user) { %>

          <div class="alert alert-info mt-4 mb-0">
            <a href="/auth/login" class="fw-semibold text-decoration-none">
              Inicia sesión
            </a> 
            para postularte a esta vacante.
          </div>

        <% } %>

      </div>
    </div>

  </main>

  <%- include('../partials/footer') %>
</body>
</html>
