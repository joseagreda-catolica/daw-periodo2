<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container mt-4">

    <h2 class="fw-bold mb-4">Mis Solicitudes</h2>

    <% if (postulaciones.length === 0) { %>
      <p class="text-muted">
        No has enviado postulaciones aún. 
        <a href="/vacantes" class="fw-semibold text-decoration-none">Buscar empleos</a>
      </p>
    <% } else { %>

      <div class="card shadow-sm border-0">
        <div class="card-body p-0">

          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Puesto</th>
                  <th>Empresa</th>
                  <th>Ubicación</th>
                  <th>Estado</th>
                  <th>Fecha</th>
                </tr>
              </thead>
              <tbody>

                <% postulaciones.forEach(p => { %>
                  <tr>

                    <td>
                      <a href="/vacantes/<%= p.id_vacante %>" class="text-decoration-none fw-semibold text-dark">
                        <%= p.titulo %>
                      </a>
                    </td>

                    <td><%= p.nombre_empresa %></td>

                    <td><%= p.ubicacion || '-' %></td>

                    <td>
                      <span class="badge 
                        <%= p.estado === 'enviada' ? 'bg-secondary' :
                            p.estado === 'en_revision' ? 'bg-info text-dark' :
                            p.estado === 'entrevista' ? 'bg-primary' :
                            p.estado === 'rechazada' ? 'bg-danger' :
                            'bg-success' %>">
                        <%= p.estado %>
                      </span>
                    </td>

                    <td>
                      <%= new Date(p.fecha_postulacion).toLocaleDateString('es') %>
                    </td>

                  </tr>
                <% }) %>

              </tbody>
            </table>
          </div>

        </div>
      </div>

    <% } %>

  </main>

  <%- include('../partials/footer') %>
</body>
</html>
