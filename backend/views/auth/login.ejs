<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar Sesión - Portal de Trabajo</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-md bg-azul-oscuro">
  <div class="container-fluid px-3">
    <a class="navbar-brand text-white fw-bold" href="/">Portal de Trabajo SV</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navLogin">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navLogin">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link text-white" href="/vacantes">EMPLEOS</a></li>
        <li class="nav-item"><a class="nav-link text-white" href="/recursos">RECURSOS</a></li>
      </ul>
      <a class="btn btn-warning" href="/auth/register">Registrarse</a>
    </div>
  </div>
</nav>

<div class="d-flex flex-grow-1">
  <div class="row w-100 m-0 align-items-start align-items-md-stretch">

    <!-- Columna izquierda -->
    <div class="col-md-6 d-flex bg-azul-oscuro">
      <div class="m-auto px-3 w-75">
        <h5 class="fs-3 w-75 text-white">Accede a miles de oportunidades laborales</h5>
        <p class="fw-normal text-white-50">Gestiona tus postulaciones y conecta con las mejores empresas de El Salvador.</p>
        <ul class="li-marker-yellow fw-normal text-white">
          <li>Postúlate con un Click</li>
          <li>Alertas de empleo personalizadas</li>
          <li>Estadísticas de tu perfil</li>
          <li>Valorar empresas donde trabajaste</li>
        </ul>
      </div>
    </div>

    <!-- Columna derecha -->
    <div class="col-md-6 bg-beige-suave">
      <div class="p-4 mt-4">
        <h5 class="fs-4">Bienvenido de nuevo</h5>
        <p class="fw-normal text-secondary">Ingresa tus credenciales para continuar</p>

        <% if (error && error.length > 0) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <% if (success && success.length > 0) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>

        <form action="/auth/login" method="POST" class="d-flex flex-column gap-3 mt-3">
          <div>
            <label for="email" class="form-label">Correo Electrónico</label>
            <input type="email" id="email" name="email" placeholder="tu@correo.com" class="form-control" required>
          </div>
          <div>
            <label for="password" class="form-label">Contraseña</label>
            <input type="password" id="password" name="password" placeholder="••••••••" class="form-control" required>
          </div>

          <button type="submit" class="btn btn-primary w-100">Iniciar Sesión</button>
        </form>

        <p class="text-center mt-3">
          No tienes una cuenta?
          <a href="/auth/register">Regístrate gratis</a>
        </p>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
