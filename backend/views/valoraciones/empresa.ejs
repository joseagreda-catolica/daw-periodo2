<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container mt-4">

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <a href="/valoraciones" class="btn btn-outline-secondary btn-sm mb-3">
      ← Volver
    </a>

    <div class="card shadow-sm border-0 mb-4">
      <div class="card-body">

        <h3 class="fw-bold mb-1"><%= empresa.nombre_empresa %></h3>

        <p class="text-muted mb-3">
          <%= empresa.sector || '' %> &middot; <%= empresa.ubicacion || '' %>
        </p>

        <div class="d-flex align-items-center gap-3">

          <span class="display-6 fw-bold text-primary">
            <%= promedio ? parseFloat(promedio).toFixed(1) : 'N/A' %>
          </span>

          <div>
            <div class="text-warning">
              <% for(let i = 1; i <= 5; i++) { %>
                <span><%= promedio && i <= Math.round(promedio) ? '★' : '☆' %></span>
              <% } %>
            </div>
            <small class="text-muted">
              <%= valoraciones.length %> valoraciones
            </small>
          </div>

        </div>

      </div>
    </div>

    <% if (user && user.rol === 'candidato') { %>
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

          <h5 class="fw-semibold mb-3">Deja tu valoración</h5>

          <form action="/valoraciones/empresa/<%= empresa.id_empresa %>" method="POST">

            <div class="mb-3">
              <label class="form-label">Puntuación</label>
              <div class="text-warning fs-4">
                <% for(let i = 1; i <= 5; i++) { %>
                  <label class="me-2">
                    <input type="radio" name="puntuacion" value="<%= i %>" required class="form-check-input me-1">
                    ★
                  </label>
                <% } %>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label">Comentario (opcional)</label>
              <textarea 
                name="comentario" 
                class="form-control" 
                rows="3" 
                placeholder="Comparte tu experiencia con esta empresa..."
              ></textarea>
            </div>

            <button type="submit" class="btn btn-primary">
              Enviar Valoración
            </button>

          </form>

        </div>
      </div>
    <% } %>

    <h4 class="fw-semibold mb-3">Opiniones</h4>

    <% if (valoraciones.length === 0) { %>
      <p class="text-muted">Esta empresa aún no tiene valoraciones.</p>
    <% } %>

    <div class="d-flex flex-column gap-3">
      <% valoraciones.forEach(v => { %>
        <div class="card shadow-sm border-0">
          <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
              <strong><%= v.nombre %> <%= v.apellido %></strong>

              <div class="text-warning">
                <% for(let i = 1; i <= 5; i++) { %>
                  <span><%= i <= v.puntuacion ? '★' : '☆' %></span>
                <% } %>
              </div>

              <small class="text-muted">
                <%= new Date(v.fecha_valoracion).toLocaleDateString('es') %>
              </small>
            </div>

            <% if (v.comentario) { %>
              <p class="mb-0"><%= v.comentario %></p>
            <% } %>

          </div>
        </div>
      <% }) %>
    </div>

  </main>

  <%- include('../partials/footer') %>
</body>
</html>
