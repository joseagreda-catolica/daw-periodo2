<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container mt-4">

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <!-- VOLVER -->
    <a href="/foros" class="btn btn-outline-secondary btn-sm mb-3">
      ← Volver al Foro
    </a>

    <!-- TEMA -->
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-body">

        <h2 class="fw-bold mb-2"><%= tema.titulo %></h2>

        <p class="text-muted small mb-3">
          Por <strong><%= tema.nombre %> <%= tema.apellido %></strong>
          &middot; <%= new Date(tema.fecha_publicacion).toLocaleDateString('es') %>
        </p>

        <div class="text-secondary">
          <p class="mb-0"><%= tema.contenido %></p>
        </div>

      </div>
    </div>

    <!-- RESPUESTAS -->
    <h4 class="fw-semibold mb-3">
      Respuestas (<%= respuestas.length %>)
    </h4>

    <% if (respuestas.length === 0) { %>
      <p class="text-muted">Aún no hay respuestas. ¡Sé el primero en responder!</p>
    <% } %>

    <div class="d-flex flex-column gap-3">
      <% respuestas.forEach(r => { %>

        <div class="card shadow-sm border-0">
          <div class="card-body">

            <p class="text-muted small mb-2">
              <strong><%= r.nombre %> <%= r.apellido %></strong>
              &middot; <%= new Date(r.fecha_respuesta).toLocaleDateString('es') %>
            </p>

            <p class="mb-0"><%= r.contenido %></p>

          </div>
        </div>

      <% }) %>
    </div>

    <!-- RESPONDER -->
    <% if (user) { %>
      <div class="card shadow-sm border-0 mt-4">
        <div class="card-body">

          <h5 class="fw-semibold mb-3">Tu respuesta</h5>

          <form action="/foros/<%= tema.id_tema %>/responder" method="POST">
            <div class="mb-3">
              <textarea 
                name="contenido" 
                class="form-control" 
                rows="5" 
                placeholder="Escribe tu respuesta..." 
                required
              ></textarea>
            </div>

            <button type="submit" class="btn btn-primary">
              Publicar Respuesta
            </button>
          </form>

        </div>
      </div>

    <% } else { %>

      <div class="alert alert-info mt-4">
        <a href="/login" class="fw-semibold text-decoration-none">
          Inicia sesión
        </a> 
        para responder en el foro.
      </div>

    <% } %>

  </main>

  <%- include('../partials/footer') %>
</body>
</html>
