<header class="navbar navbar-expand-lg bg-light-subtle shadow-sm">
  <div class="container">

    <!-- LOGO -->
    <a href="/" class="navbar-brand fw-bold">
      Portal de Trabajo
    </a>

    <!-- BOTON MOBILE -->
    <button 
      class="navbar-toggler" 
      type="button" 
      data-bs-toggle="collapse" 
      data-bs-target="#navbarContent"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- NAV -->
    <div class="collapse navbar-collapse" id="navbarContent">

      <!-- LINKS -->
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link" href="/vacantes">Buscar Empleos</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/recursos">Recursos</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/valoraciones">Valoraciones</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/foros">Foros</a>
        </li>

        <% if (user) { %>
          <% if (user.rol === 'candidato') { %>
            <li class="nav-item">
              <a class="nav-link" href="/candidato/perfil">Mi Perfil</a>
            </li>
          <% } else if (user.rol === 'empresa') { %>
            <li class="nav-item">
              <a class="nav-link" href="/empresa/panel">Panel Empresa</a>
            </li>
          <% } else if (user.rol === 'admin') { %>
            <li class="nav-item">
              <a class="nav-link" href="/admin">Admin</a>
            </li>
          <% } %>
        <% } %>
      </ul>

      <!-- DERECHA -->
      <div class="d-flex align-items-center gap-2">

        <% if (user) { %>
          <span class="fw-semibold text-secondary">
            <%= user.nombre %>
          </span>

          <a href="/auth/logout" class="btn btn-outline-secondary btn-sm">
            Cerrar Sesión
          </a>

        <% } else { %>

          <a href="/auth/login" class="btn btn-outline-secondary btn-sm">
            Iniciar Sesión
          </a>

          <a href="/auth/register" class="btn btn-primary btn-sm">
            Registrarse
          </a>

        <% } %>

      </div>

    </div>
  </div>
</header>